{
	"name": "viewitall-md",
	"version": "0.1.0",
	"description": "View and edit MS Word (.docx) and PDF files directly inside Obsidian.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
