# ══════════════════════════════════════════════════════════════
#  FUTURE FILE TYPES  (planned — not yet implemented)
# ══════════════════════════════════════════════════════════════

[[req]]
id       = "FT-01"
title    = "Spreadsheet viewer for .xlsx and .csv"
status   = "planned"
priority = 2
sprint   = 6
notes    = """
  Library: SheetJS (xlsx) — browser-compatible, no native deps.
  Render: SheetJS → 2D array → HTML table with frozen header row.
  .csv: parse manually or via SheetJS read().
  Features: column resize, sort by column, row count indicator.
  Settings: maxRowsToRender (default 2000 for performance).
  Toggle: enableXlsx + enableCsv in settings.
"""

[[req]]
id       = "FT-02"
title    = "Presentation viewer for .pptx"
status   = "planned"
priority = 2
sprint   = 7
notes    = """
  Library: pptxgenjs can READ pptx (use the parse side), or use
  officeparser / pptx2html for rendering.
  Render: each slide as a scaled canvas or positioned HTML div.
  Navigation: prev/next slide buttons + slide thumbnail strip.
  Features: slide count, full-screen mode.
  Toggle: enablePptx in settings.
  Complexity: High — consider a 2-phase approach:
    Phase 1: text-only extraction view
    Phase 2: visual slide rendering
"""

[[req]]
id       = "FT-03"
title    = "eBook viewer for .epub"
status   = "planned"
priority = 3
sprint   = 8
notes    = """
  Library: epub.js (epubjs) — well-maintained, browser-ready.
  Render: paginated or scrolling view inside an iframe/div.
  Features: chapter navigation (TOC), font size, reading position memory.
  Toggle: enableEpub in settings.
"""

[[req]]
id       = "FT-04"
title    = "Media player for .mp4 / .webm / .mp3 / .ogg / .wav"
status   = "planned"
priority = 3
sprint   = 6
notes    = """
  Library: None needed — native HTML5 <video> and <audio> elements.
  Render: styled HTML5 player with Obsidian-themed controls.
  Note: Obsidian already opens some media types; only override if
  the native handling is lacking (e.g., no loop/speed controls).
  Features: playback speed, loop toggle, volume memory.
  Toggle: enableMedia in settings.
"""

[[req]]
id       = "FT-05"
title    = "Code / data file viewer for .json / .yaml / .xml / .toml"
status   = "planned"
priority = 3
sprint   = 6
notes    = """
  Library: highlight.js or Prism (already used by Obsidian internally).
  Render: syntax-highlighted read-only code block.
  For JSON/XML: collapsible tree view option.
  Toggle: enableCodeView in settings.
  Note: these files can already be opened as text in Obsidian — only
  add if we can provide meaningfully better rendering (e.g. tree view).
"""

[[req]]
id       = "FT-06"
title    = "Archive inspector for .zip"
status   = "planned"
priority = 4
sprint   = 9
notes    = """
  Library: JSZip — browser-compatible.
  Render: file tree with size, type, and date columns.
  Features: preview individual text files inside the archive.
  Toggle: enableZip in settings.
"""

[[req]]
id       = "FT-07"
title    = "3D model viewer for .glb / .gltf"
status   = "planned"
priority = 5
sprint   = "future"
notes    = """
  Library: Three.js or Babylon.js — large dependency (~500kb min).
  Render: WebGL canvas with orbit controls (rotate, zoom, pan).
  Only add if bundle size impact is acceptable (lazy-load the lib).
  Toggle: enable3d in settings.
"""

[[req]]
id       = "FT-08"
title    = "Rich text viewer for .odt / .rtf"
status   = "planned"
priority = 4
sprint   = "future"
notes    = """
  .odt: similar mammoth approach; may require a different library.
  .rtf: rtf.js or rtfparser library.
  Toggle: enableOdt / enableRtf in settings.
"""
