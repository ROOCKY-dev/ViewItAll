# ============================================================
#  ViewItAll-md — .Agent/requirements.toon
#  ALL REQUIREMENTS  •  achieved + planned  •  priority order
# ============================================================
#
#  STATUS values:  done | in-progress | planned | blocked | cancelled
#  PRIORITY:       1 = critical  2 = high  3 = medium  4 = low  5 = future
#  SPRINT:         which sprint delivered (or will deliver) this
#
# ============================================================

[meta]
format       = "custom-toml-like/1.0"
last_updated = "2026-03-11"
version      = "1.4.1"


# ══════════════════════════════════════════════════════════════
#  CORE PLATFORM
# ══════════════════════════════════════════════════════════════

[[req]]
id       = "CORE-01"
title    = "Register custom FileView for .pdf files"
status   = "done"
priority = 1
sprint   = 1
notes    = "PdfView extends FileView; registered in main.ts onload()"

[[req]]
id       = "CORE-02"
title    = "Register custom FileView for .docx files"
status   = "done"
priority = 1
sprint   = 1
notes    = "DocxView extends FileView; registered in main.ts onload()"

[[req]]
id       = "CORE-03"
title    = "Plugin settings tab with all configurable options"
status   = "done"
priority = 1
sprint   = 4
notes    = "Full PluginSettings interface; sections: DOCX, PDF General, Annotation Tools, Snap, Keyboard Shortcuts"

[[req]]
id       = "CORE-04"
title    = "No hardcoded keyboard shortcuts or defaults"
status   = "done"
priority = 1
sprint   = 4
notes    = "All shortcuts and defaults read from settings at runtime"

[[req]]
id       = "CORE-05"
title    = "Semantic versioning with auto-bump workflow"
status   = "done"
priority = 2
sprint   = 1
notes    = "npm version patch/minor/major; version-bump.mjs syncs manifest.json and versions.json"

[[req]]
id       = "CORE-06"
title    = "Toggle file-type support per type (enable/disable per extension)"
status   = "planned"
priority = 2
sprint   = 6
notes    = "Settings toggles: enablePdf, enableDocx, enableXlsx, enablePptx, enableEpub, etc."


